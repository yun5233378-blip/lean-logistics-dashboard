[Unit]
Description=Lean Logistics Dashboard FastAPI Service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/lean-logistics-dashboard
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/lean-logistics-dashboard/.venv/bin/uvicorn backend.app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
