# If this server already uses Caddy on ports 80/443, add a separate site block
# for this project instead of mounting it under another project's path.
#
# DNS requirement:
#   logistics.void52.site A 43.156.180.164

logistics.void52.site {
    encode gzip
    reverse_proxy 172.19.0.1:8000
}

# Optional IP fallback. Use this only when no other site needs the bare IP.
http://43.156.180.164 {
    encode gzip
    reverse_proxy 172.19.0.1:8000
}

